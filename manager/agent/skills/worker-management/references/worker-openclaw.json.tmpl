{
  "gateway": {
    "mode": "local",
    "port": 18800,
    "auth": {
      "token": "${WORKER_GATEWAY_AUTH_TOKEN}"
    }
  },

  "channels": {
    "matrix": {
      "enabled": true,
      "homeserver": "${HICLAW_MATRIX_SERVER}",
      "accessToken": "${WORKER_MATRIX_TOKEN}",
      "dm": {
        "policy": "allowlist",
        "allowFrom": []
      },
      "groupPolicy": "allowlist",
      "groupAllowFrom": [
        "@manager:${HICLAW_MATRIX_DOMAIN}",
        "@${HICLAW_ADMIN_USER}:${HICLAW_MATRIX_DOMAIN}"
      ],
      "groups": {
        "*": { "allow": true, "requireMention": true }
      }
    }
  },

  "models": {
    "mode": "merge",
    "providers": {
      "hiclaw-gateway": {
        "baseUrl": "${HICLAW_AI_GATEWAY}/v1",
        "apiKey": "${WORKER_GATEWAY_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "${HICLAW_DEFAULT_MODEL}",
            "name": "${HICLAW_DEFAULT_MODEL}",
            "reasoning": ${MODEL_REASONING},
            "contextWindow": ${MODEL_CONTEXT_WINDOW},
            "maxTokens": ${MODEL_MAX_TOKENS}
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "workspace": "~",
      "model": {
        "primary": "hiclaw-gateway/${HICLAW_DEFAULT_MODEL}"
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      }
    }
  },

  "session": {
    "resetByType": {
      "dm":    { "mode": "daily", "atHour": 4 },
      "group": { "mode": "idle",  "idleMinutes": 2880 }
    }
  },

  "plugins": {
    "load": {
      "paths": ["/opt/openclaw/extensions/matrix"]
    },
    "entries": {
      "matrix": { "enabled": true }
    }
  }
}
